# ------------------------------------------------------------------------------
# Hayagriva Configuration Environment Variables
# Copy this file to '.env' and fill in your details
# ------------------------------------------------------------------------------

# --- Application Server ---
PORT=8000

# --- Cloud Mode Settings (Optional) ---
# To activate Cloud Mode, provide a Gemini API key.
# Without it, Hayagriva runs in Local Mode using Ollama and CPU embeddings.
GEMINI_API_KEY=

# --- Cloud Vector Database (Optional) ---
# Optional: To use Qdrant Cloud instead of local ChromaDB, provide these keys.
QDRANT_URL=
QDRANT_API_KEY=
